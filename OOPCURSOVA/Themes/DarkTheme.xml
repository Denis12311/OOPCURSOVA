<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Основные цвета -->
	<Color x:Key="WindowColor">#FF1E1E1E</Color>
	<Color x:Key="TextColor">#FFF0F0F0</Color>
	<Color x:Key="ButtonBackgroundColor">#FF2D2D30</Color>
	<Color x:Key="ButtonForegroundColor">#FFF0F0F0</Color>
	<Color x:Key="TextBoxBackgroundColor">#FF2D2D30</Color>
	<Color x:Key="TextBoxBorderColor">#FF3E3E42</Color>
	<Color x:Key="DataGridBackgroundColor">#FF2D2D30</Color>
	<Color x:Key="DataGridForegroundColor">#FFF0F0F0</Color>
	<Color x:Key="DataGridHeaderBackgroundColor">#FF3E3E42</Color>
	<Color x:Key="DataGridHeaderForegroundColor">#FFF0F0F0</Color>
	<Color x:Key="DataGridRowAlternateColor">#FF262626</Color>

	<!-- Кисти -->
	<SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowColor}"/>
	<SolidColorBrush x:Key="TextColor" Color="{StaticResource TextColor}"/>
	<SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource ButtonBackgroundColor}"/>
	<SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource ButtonForegroundColor}"/>
	<SolidColorBrush x:Key="TextBoxBackground" Color="{StaticResource TextBoxBackgroundColor}"/>
	<SolidColorBrush x:Key="TextBoxForeground" Color="{StaticResource TextColor}"/>
	<SolidColorBrush x:Key="TextBoxBorderBrush" Color="{StaticResource TextBoxBorderColor}"/>
	<SolidColorBrush x:Key="DataGridBackground" Color="{StaticResource DataGridBackgroundColor}"/>
	<SolidColorBrush x:Key="DataGridForeground" Color="{StaticResource DataGridForegroundColor}"/>
	<SolidColorBrush x:Key="DataGridHeaderBackground" Color="{StaticResource DataGridHeaderBackgroundColor}"/>
	<SolidColorBrush x:Key="DataGridHeaderForeground" Color="{StaticResource DataGridHeaderForegroundColor}"/>
	<SolidColorBrush x:Key="DataGridRowBackground" Color="{StaticResource DataGridBackgroundColor}"/>
	<SolidColorBrush x:Key="DataGridRowAlternateBackground" Color="{StaticResource DataGridRowAlternateColor}"/>

	<!-- Стиль заголовков DataGrid -->
	<Style x:Key="DarkDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
		<Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}"/>
		<Setter Property="Foreground" Value="{DynamicResource DataGridHeaderForeground}"/>
		<Setter Property="FontWeight" Value="Bold"/>
	</Style>

	<!-- Стиль TextBox -->
	<Style TargetType="TextBox">
		<Setter Property="Background" Value="{DynamicResource TextBoxBackground}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextBoxForeground}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorderBrush}"/>
		<Setter Property="CaretBrush" Value="{DynamicResource TextBoxForeground}"/>
	</Style>
	<!-- Стиль Button -->
	<Style TargetType="Button">
		<Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
		<Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
	</Style>
</ResourceDictionary>
